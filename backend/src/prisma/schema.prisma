generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model md_roles {
  id           Int       @id @default(autoincrement())
  name         String    @db.VarChar(50)
  display_name String    @db.VarChar(50)
  created_at   DateTime  @default(now())
  users        md_users[]

  @@map("md_roles")
}

model md_clients {
  id                 Int           @id @default(autoincrement())
  name               String        @db.VarChar(100)
  dialdesk_client_id Int           @unique
  logo_url           String?       @db.VarChar(255)
  is_active          Boolean       @default(true)
  created_at         DateTime      @default(now())
  users              md_users[]
  processes          md_processes[]

  @@map("md_clients")
}

model md_users {
  id            Int                       @id @default(autoincrement())
  name          String                    @db.VarChar(100)
  email         String                    @unique @db.VarChar(150)
  password_hash String                    @db.VarChar(255)
  role_id       Int
  client_id     Int?
  is_active     Boolean                   @default(true)
  last_login    DateTime?
  created_at    DateTime                  @default(now())
  role          md_roles                  @relation(fields: [role_id], references: [id])
  client        md_clients?               @relation(fields: [client_id], references: [id])
  dashboard_access md_dashboard_access[]
  process_mappings md_user_process_mapping[]
  login_logs    md_login_logs[]
  audit_logs    md_audit_logs[]

  @@map("md_users")
}

model md_processes {
  id                 Int                       @id @default(autoincrement())
  client_id          Int
  process_name       String                    @db.VarChar(100)
  lob                String                    @db.VarChar(20)
  dialdesk_client_id Int
  is_active          Boolean                   @default(true)
  client             md_clients                @relation(fields: [client_id], references: [id])
  user_mappings      md_user_process_mapping[]

  @@map("md_processes")
}

model md_dashboards {
  id          Int                     @id @default(autoincrement())
  name        String                  @db.VarChar(100)
  slug        String                  @unique @db.VarChar(100)
  icon        String                  @db.VarChar(50)
  description String?                 @db.Text
  is_active   Boolean                 @default(true)
  sort_order  Int                     @default(0)
  access      md_dashboard_access[]

  @@map("md_dashboards")
}

model md_dashboard_access {
  id           Int           @id @default(autoincrement())
  user_id      Int
  dashboard_id Int
  can_export   Boolean       @default(false)
  granted_by   Int?
  granted_at   DateTime      @default(now())
  user         md_users      @relation(fields: [user_id], references: [id])
  dashboard    md_dashboards @relation(fields: [dashboard_id], references: [id])

  @@unique([user_id, dashboard_id])
  @@map("md_dashboard_access")
}

model md_user_process_mapping {
  id          Int          @id @default(autoincrement())
  user_id     Int
  process_id  Int
  assigned_at DateTime     @default(now())
  user        md_users     @relation(fields: [user_id], references: [id])
  process     md_processes @relation(fields: [process_id], references: [id])

  @@unique([user_id, process_id])
  @@map("md_user_process_mapping")
}

model md_login_logs {
  id         Int      @id @default(autoincrement())
  user_id    Int
  ip_address String   @db.VarChar(45)
  user_agent String?  @db.Text
  status     String   @db.VarChar(10)
  logged_at  DateTime @default(now())
  user       md_users @relation(fields: [user_id], references: [id])

  @@map("md_login_logs")
}

model md_audit_logs {
  id          Int      @id @default(autoincrement())
  user_id     Int
  action      String   @db.VarChar(100)
  entity_type String?  @db.VarChar(50)
  entity_id   Int?
  old_values  Json?
  new_values  Json?
  created_at  DateTime @default(now())
  user        md_users @relation(fields: [user_id], references: [id])

  @@map("md_audit_logs")
}
